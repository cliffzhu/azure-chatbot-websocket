{
  "name": "azure-chatbot-websocket",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted Teams bot runtime that bridges to a websocket backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "azure-chatbot-websocket": "file:",
    "botbuilder": "^4.23.2",
