# Copy this file to .env and replace placeholders.
# Use NODE_ENV=development for local simulation endpoints (/api/simulate, /api/dev/messages).
# Use NODE_ENV=production to disable those dev endpoints in production.
NODE_ENV=development
PORT=3978
LOG_LEVEL=debug

# Azure AI Bot Service credentials (Azure App Registration)
MicrosoftAppType=SingleTenant
MicrosoftAppId=YOUR_BOT_APP_ID
MicrosoftAppPassword=YOUR_BOT_APP_PASSWORD
MicrosoftAppTenantId=YOUR_TENANT_ID

# Optional single-gate mode for incoming JWT authenticity verification.
# false: default CloudAdapter authentication on /api/messages.
# true: bypass CloudAdapter auth and use only JWT validation on /api/messages.
JWT_ONLY_AUTH_ENABLED=false
JWT_AUTH_REQUIRED_PATH_PREFIX=/api/messages
JWT_AUTH_HEADER=Authorization

# Required when JWT_ONLY_AUTH_ENABLED=true.
# Option A (provider-agnostic): set exact OpenID discovery URL + issuer allow-list.
OPENID_CONFIGURATION_URL=

# Option B (Azure shortcut): set tenant + token version to auto-build OpenID URL.
JWT_TENANT_ID=YOUR_TENANT_ID
JWT_TOKEN_VERSION=v2.0

# Always required in JWT-only mode: exact audience expected in incoming tokens.
JWT_EXPECTED_AUDIENCE=YOUR_EXPECTED_AUDIENCE

# Optional overrides for issuer list and verification behavior.
# Comma-separated issuer allow-list.
# Example for v2.0 + legacy issuer format:
# JWT_ALLOWED_ISSUERS=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0,https://sts.windows.net/YOUR_TENANT_ID/
# If blank and JWT_TENANT_ID is set, Azure defaults are derived automatically.
JWT_ALLOWED_ISSUERS=
JWKS_CACHE_TTL_SECONDS=3600
JWT_CLOCK_SKEW_SECONDS=300

# Outgoing channel send logs (attempt/success/failure) for CloudAdapter paths.
# Set to false in production if you want less verbose logs.
OUTGOING_ACTIVITY_LOG_ENABLED=true

# Experimental progressive response mode.
# true: periodically send Bot Framework typing activities while backend chunks stream in.
# false: buffer the entire backend response and send a single final message.
# Note: Teams does not reliably support true token-by-token streaming UI.
STREAMING_RESPONSES_ENABLED=false

# WebSocket backend settings
WEBSOCKET_URL=wss://YOUR_BACKEND_HOST/ws
WEBSOCKET_AUTH_TOKEN=YOUR_BACKEND_TOKEN
# Optional default session config options applied after session/new.
# Preferred: set WEBSOCKET_AGENT_NAME when backend supports agent config.
WEBSOCKET_AGENT_NAME=
# Optional fallback for backends that expect model config instead of agent config.
WEBSOCKET_MODEL_NAME=
WEBSOCKET_CONNECT_TIMEOUT_MS=10000
WEBSOCKET_RECONNECT_MAX_ATTEMPTS=10
WEBSOCKET_RECONNECT_BACKOFF_MS=1000

# Optional local health endpoint
ENABLE_HEALTH_ENDPOINT=true
HEALTH_ENDPOINT_PATH=/healthz

# Azure resource naming (dev)
AZURE_LOCATION=eastus
AZURE_ENV=dev
AZURE_RESOURCE_GROUP=rg-yourprefix-bot-dev
AZURE_BOT_NAME=bot-yourprefix-dev
AZURE_CONTAINER_APP_NAME=ca-yourprefix-bot-dev
AZURE_CONTAINER_REGISTRY=cryourprefixdev
AZURE_KEY_VAULT=kv-yourprefix-bot-dev
AZURE_LOG_ANALYTICS=log-yourprefix-bot-dev
